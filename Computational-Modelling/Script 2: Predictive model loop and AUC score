progress_env$done <- 0

# Progress function with ETA
progress_eta <- function(n) {
  progress_env$done <- progress_env$done + 1
  elapsed <- as.numeric(Sys.time() - progress_env$start_time, units = "secs")
  avg_time <- elapsed / progress_env$done
  remaining <- avg_time * (n_permutations - progress_env$done)
  
  # Smart unit selection
  if (remaining < 60) {
    cat(sprintf("\rProgress: %d/%d | ETA: ~%.1f sec remaining", 
                progress_env$done, n_permutations, remaining))
  } else if (remaining < 3600) {
    cat(sprintf("\rProgress: %d/%d | ETA: ~%.1f min remaining", 
                progress_env$done, n_permutations, remaining / 60))
  } else {
    cat(sprintf("\rProgress: %d/%d | ETA: ~%.2f hr remaining", 
                progress_env$done, n_permutations, remaining / 3600))
  }
  
  flush.console()
}
